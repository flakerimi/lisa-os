# Maintainer: Lisa OS project <https://github.com/Lisa-AgenticOS/lisa-os>
# Split package for the Lisa Layer (Track L, ADR-0003). Built from a
# git-archive tarball produced by os/repo-tools/build-packages.sh — the
# checksum is SKIP because the tarball is generated locally from git HEAD;
# the hosted repo (M1) ships signed packages instead (PLAN §5.10).

pkgbase=lisa
pkgname=(lisa-inferenced lisa-modeld lisa-cli lisa-shell lisa-portal)
pkgver=0.1.0
pkgrel=1
pkgdesc="Lisa OS AI layer: local inference as a system service"
arch=(x86_64 aarch64)
url="https://github.com/Lisa-AgenticOS/lisa-os"
license=(GPL-2.0-only)
# glib2: glib-compile-schemas for the lisa-shell extension schema.
makedepends=(cargo glib2)
# makepkg's default lto option injects -flto into ring's C objects, which
# ld.lld cannot resolve at link time (cross-language LTO breakage).
options=(!lto)
source=("$pkgbase-$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
    cd "$pkgbase-$pkgver"
    export CARGO_HOME="$srcdir/cargo-home"
    cargo fetch --locked
}

build() {
    cd "$pkgbase-$pkgver"
    export CARGO_HOME="$srcdir/cargo-home"
    cargo build --release --locked --workspace
}

check() {
    cd "$pkgbase-$pkgver"
    export CARGO_HOME="$srcdir/cargo-home"
    cargo test --release --locked --workspace
}

package_lisa-inferenced() {
    pkgdesc="Lisa OS model runtime & scheduler (PLAN §5.1)"
    depends=(gcc-libs)
    cd "$pkgbase-$pkgver"
    install -Dm755 target/release/lisa-inferenced "$pkgdir/usr/bin/lisa-inferenced"
    install -Dm644 os/packages/lisa/lisa-inferenced.service \
        "$pkgdir/usr/lib/systemd/system/lisa-inferenced.service"
    # Per-user session-bus surface (org.lisa.Inference1) for the shell
    # surfaces; enabled for every user from first login.
    install -Dm644 os/packages/lisa/lisa-inferenced-dbus.service \
        "$pkgdir/usr/lib/systemd/user/lisa-inferenced-dbus.service"
    install -d "$pkgdir/usr/lib/systemd/user/default.target.wants"
    ln -s ../lisa-inferenced-dbus.service \
        "$pkgdir/usr/lib/systemd/user/default.target.wants/lisa-inferenced-dbus.service"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

package_lisa-modeld() {
    pkgdesc="Lisa OS model catalog & content-addressed store (PLAN §5.2)"
    depends=(gcc-libs)
    cd "$pkgbase-$pkgver"
    install -Dm755 target/release/lisa-modeld "$pkgdir/usr/bin/lisa-modeld"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    # The daemon loop + D-Bus service land in M1; binary ships for
    # store/catalog operations via the lisa CLI meanwhile.
}

package_lisa-portal() {
    pkgdesc="Lisa OS trust-boundary portal (PLAN §5.5)"
    depends=(gcc-libs)
    cd "$pkgbase-$pkgver"
    install -Dm755 target/release/xdg-desktop-portal-lisa \
        "$pkgdir/usr/bin/xdg-desktop-portal-lisa"
    install -Dm644 os/packages/lisa/xdg-desktop-portal-lisa.service \
        "$pkgdir/usr/lib/systemd/user/xdg-desktop-portal-lisa.service"
    install -Dm644 os/packages/lisa/org.lisa.Portal.service \
        "$pkgdir/usr/share/dbus-1/services/org.lisa.Portal.service"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

package_lisa-cli() {
    pkgdesc="Lisa OS command center CLI (lisa ask, lisa models, ...)"
    depends=(gcc-libs)
    cd "$pkgbase-$pkgver"
    install -Dm755 target/release/lisa "$pkgdir/usr/bin/lisa"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

package_lisa-shell() {
    pkgdesc="Lisa OS shell surfaces: assistant overlay, semantic launcher, Ledger app, AI settings (PLAN §5.7, §5.11)"
    # Pure GJS — no compiled code, so one package serves every arch.
    arch=(any)
    # gjs runs the overlay backend + Ledger app; libadwaita (pulls gtk4)
    # renders the Ledger app; lisa-cli is how surfaces reach the
    # substrate (context search, ledger reads — CLAUDE.md rule 7);
    # libqalculate ships qalc, the launcher's calculator lane (§5.7.2:
    # math routes to qalc, never the model).
    depends=(gjs libadwaita lisa-cli libqalculate)
    optdepends=('gnome-shell: overlay + launcher Shell extensions (GNOME 46+)')
    cd "$pkgbase-$pkgver"

    # Surface trees under /usr/share/lisa/shell — the path the D-Bus
    # activation file and the desktop entry already reference.
    local share="$pkgdir/usr/share/lisa/shell"
    install -d "$share"
    cp -a shell/overlay-extension shell/launcher shell/ledger-app shell/settings "$share/"
    rm -rf "$share"/*/tests
    # Compile the overlay keybinding schema in place so the extension's
    # getSettings() resolves from its own schemas/ directory.
    glib-compile-schemas "$share/overlay-extension/schemas"

    # GNOME Shell loads system extensions from
    # /usr/share/gnome-shell/extensions/<uuid>; symlinks keep
    # /usr/share/lisa/shell the single install location.
    install -d "$pkgdir/usr/share/gnome-shell/extensions"
    ln -s /usr/share/lisa/shell/overlay-extension \
        "$pkgdir/usr/share/gnome-shell/extensions/lisa-overlay@lisa-os.org"
    ln -s /usr/share/lisa/shell/launcher \
        "$pkgdir/usr/share/gnome-shell/extensions/lisa-launcher@lisa-os.org"

    # D-Bus activation for the headless overlay backend (§5.7.1).
    install -Dm644 shell/overlay-extension/backend/org.lisa.Overlay1.service \
        "$pkgdir/usr/share/dbus-1/services/org.lisa.Overlay1.service"
    # Ledger app launcher entry (§5.7.6).
    install -Dm644 shell/ledger-app/org.lisa.LedgerApp.desktop \
        "$pkgdir/usr/share/applications/org.lisa.LedgerApp.desktop"
    # AI settings launcher entry (§5.11). Also the target the native
    # gnome-control-center Intelligence panel opens for provider/key
    # management (ADR-0012) — it resolves this desktop id.
    install -Dm644 shell/settings/org.lisa.Settings.desktop \
        "$pkgdir/usr/share/applications/org.lisa.Settings.desktop"
    # Session defaults: extensions enabled; Super+Space is the
    # Spotlight-style search (§5.7.2), Super+Shift+Space the assistant
    # overlay (§5.7.1), the input-source switcher moves to
    # Ctrl+Super+Space. glib2's pacman hook folds this into the
    # compiled system schemas on install.
    install -Dm644 os/packages/lisa/10_lisa-shell.gschema.override \
        "$pkgdir/usr/share/glib-2.0/schemas/10_lisa-shell.gschema.override"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
