# gnome-control-center, Lisa build — stock upstream (pinned 50.3) plus a
# native "Intelligence" panel (ADR-0012). Derived from Arch's
# gnome-control-center PKGBUILD (50.3-1); the ONLY delta is the panel dir
# + two anchored edits applied in prepare(). Re-pinning to a new GNOME
# release: bump pkgver, rebuild, and fix the two anchors if upstream moved
# them (the guards below fail loudly if so).
#
# Built in CI / a container (arch), never on the macOS dev host. Our
# package repo is layered above [extra] so this build wins over stock.

pkgbase=gnome-control-center
pkgname=(
  gnome-control-center
  gnome-keybindings
)
pkgver=50.3
pkgrel=1
pkgdesc="GNOME's main interface to configure various aspects of the desktop (Lisa build: + Intelligence panel)"
url="https://apps.gnome.org/Settings/"
license=(GPL-2.0-or-later)
arch=(x86_64)
depends=(
  accountsservice bolt cairo colord-gtk4 cups-pk-helper dconf fontconfig
  gcr-4 gdk-pixbuf2 glib2 glibc gnome-bluetooth-3.0 gnome-color-manager
  gnome-desktop-4 gnome-online-accounts gnome-settings-daemon gnome-shell
  gnutls graphene gsettings-desktop-schemas gsound gst-plugins-good gtk4
  hicolor-icon-theme json-glib krb5 libadwaita libcolord libcups libepoxy
  libgcc libgoa libgtop libgudev libibus libmalcontent libmm-glib libnm
  libnma-gtk4 libpulse libpwquality libsecret libsoup3 libwacom libx11
  libxi libxml2 pango polkit smbclient sound-theme-freedesktop tecla
  udisks2 upower wayland
)
makedepends=(
  blueprint-compiler docbook-xsl git glib2-devel meson modemmanager
)
checkdepends=(
  python-dbusmock python-gobject xorg-server-xvfb
)
# The panel sources live beside this PKGBUILD (makepkg resolves local
# sources by basename in $startdir — no subdirs).
source=(
  "git+https://gitlab.gnome.org/GNOME/gnome-control-center.git?signed#tag=${pkgver/[a-z]/.&}"
  "git+https://gitlab.gnome.org/GNOME/libgnome-volume-control.git"
  "git+https://gitlab.gnome.org/GNOME/libgxdp.git#commit=1fe6de799f39b3126e8d0db66fa4f16c10fd9bd6"
  "cc-lisa-panel.h"
  "cc-lisa-panel.c"
  "cc-lisa-panel-meson.build"
  "gnome-lisa-panel.desktop.in"
)
b2sums=('94d45dc219e1f1e533d66e2cc9ce5daadc8030ccc2466befc7ad3f79ea8fa8928648878c4caf8b0170ea345b8a1bf3d11e14237e37175fa15f97a7fc7d92dde7'
        'SKIP'
        'a67bd121284dd5546607f21a966ae7e73a05b5cd5e90d925fa0ba710e7c877f85a7c700dded0e050ce297884201f07177cd975c5501cc62fe35c27e5285bdfa3'
        'SKIP'
        'SKIP'
        'SKIP'
        'SKIP')
validpgpkeys=(
  9B60FE7947F0A3C58136817F2C2A218742E016BE # Felipe Borges (GNOME) <felipeborges@gnome.org>
)

prepare() {
  cd $pkgbase

  git submodule init
  git submodule set-url subprojects/gvc "$srcdir/libgnome-volume-control"
  git -c protocol.file.allow=always -c protocol.allow=never submodule update

  # --- Lisa delta (ADR-0012) ---------------------------------------
  # Guard the anchors: a GNOME bump that moved them must fail loudly,
  # not silently drop our panel.
  grep -q '^extern GType cc_wellbeing_panel_get_type (void);' shell/cc-panel-loader.c \
    || { echo "cc-panel-loader.c extern anchor moved — update the Lisa patch" >&2; return 1; }
  grep -q 'PANEL_TYPE("wellbeing",' shell/cc-panel-loader.c \
    || { echo "cc-panel-loader.c PANEL_TYPE anchor moved — update the Lisa patch" >&2; return 1; }
  grep -q "^  'wellbeing'," panels/meson.build \
    || { echo "panels/meson.build anchor moved — update the Lisa patch" >&2; return 1; }

  # Drop in the panel.
  install -d panels/lisa
  install -m644 "$srcdir"/cc-lisa-panel.h            panels/lisa/cc-lisa-panel.h
  install -m644 "$srcdir"/cc-lisa-panel.c            panels/lisa/cc-lisa-panel.c
  install -m644 "$srcdir"/cc-lisa-panel-meson.build  panels/lisa/meson.build
  install -m644 "$srcdir"/gnome-lisa-panel.desktop.in \
    panels/lisa/gnome-lisa-panel.desktop.in

  # Register it: build the panel lib, declare the GType, and list it.
  sed -i "s/^  'wellbeing',\$/  'wellbeing',\n  'lisa',/" panels/meson.build
  sed -i '/^extern GType cc_wellbeing_panel_get_type (void);/a extern GType cc_lisa_panel_get_type (void);' \
    shell/cc-panel-loader.c
  sed -i '/PANEL_TYPE("wellbeing",/a\  PANEL_TYPE("lisa",             cc_lisa_panel_get_type,                 NULL),' \
    shell/cc-panel-loader.c
}

build() {
  local meson_options=(
    -D documentation=true
    -D location-services=enabled
    -D malcontent=true
  )

  export MESON_PACKAGE_CACHE_DIR="$srcdir"

  arch-meson $pkgbase build "${meson_options[@]}"
  meson compile -C build
}

check() {
  GTK_A11Y=none dbus-run-session xvfb-run -s '-nolisten local +iglx -noreset' \
    meson test -C build --print-errorlogs
}

_pick() {
  local p="$1" f d; shift
  for f; do
    d="$srcdir/$p/${f#$pkgdir/}"
    mkdir -p "$(dirname "$d")"
    mv "$f" "$d"
    rmdir -p --ignore-fail-on-non-empty "$(dirname "$f")"
  done
}

package_gnome-control-center() {
  depends+=(gnome-keybindings)
  optdepends=(
    'fwupd: device security panel'
    'gnome-remote-desktop: screen sharing'
    'gnome-user-share: WebDAV file sharing'
    'malcontent: application permission control'
    'networkmanager: network settings'
    'openssh: remote login'
    'power-profiles-daemon: power profiles'
    'rygel: media sharing'
    'system-config-printer: printer settings'
  )
  groups=(gnome)

  meson install -C build --destdir "$pkgdir"

  cd "$pkgdir"
  _pick gkb usr/share/gettext/its/gnome-keybindings.*
  _pick gkb usr/share/gnome-control-center/keybindings
  _pick gkb usr/share/pkgconfig/gnome-keybindings.pc
}

package_gnome-keybindings() {
  pkgdesc="Keybindings configuration for GNOME applications"
  depends=()

  mv gkb/* "$pkgdir"
}

